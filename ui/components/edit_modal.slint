// ============================================
// Component: EditModal
// Pantalla 4 — Modal de edición de proceso
// ============================================

import { KernelColors } from "../theme/colors.slint";
import { KernelTypo } from "../theme/typography.slint";
import { HudCard } from "common/hud_card.slint";
import { HudButton } from "common/hud_button.slint";
import { HudSlider } from "common/hud_slider.slint";
import { LineEdit, SpinBox } from "std-widgets.slint";

export component EditModal inherits Rectangle {
    in-out property <string> process-pid-hex: "";
    in-out property <int> process-pid: 0;
    in-out property <string> process-name: "";
    in-out property <int> process-burst: 0;
    in-out property <int> process-priority: 5;
    callback save(int, string, int, int);
    callback cancel();

    background: #000000cc;
    TouchArea { clicked => { root.cancel(); } }

    Rectangle {
        width: 480px;
        height: 420px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        HudCard {
            width: 100%;
            height: 100%;
            show-corners: true;
            corner-size: 18px;

            TouchArea { }

            VerticalLayout {
                padding: 32px;
                spacing: 24px;

                HorizontalLayout {
                    spacing: 12px;
                    Rectangle {
                        width: 36px; height: 36px;
                        background: #38bdf820;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: KernelColors.accent-cyan;
                        Text { text: "✎"; font-size: 18px; color: KernelColors.accent-cyan; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "EDIT PROCESS"; font-size: 20px; font-weight: 800; color: KernelColors.text-primary; letter-spacing: 1px; }
                        Text { text: "ID: " + process-pid-hex; font-size: 12px; color: KernelColors.text-muted; }
                    }
                }

                Rectangle { height: 1px; background: KernelColors.border-default; }

                VerticalLayout {
                    spacing: 6px;
                    Text { text: "PROCESS NAME"; font-size: 10px; font-weight: 700; color: KernelColors.text-secondary; letter-spacing: 1.5px; }
                    Rectangle {
                        height: 38px; background: KernelColors.bg-input; border-radius: 2px; border-width: 1px; border-color: KernelColors.border-default;
                        LineEdit { text: root.process-name; font-size: 14px; edited(t) => { root.process-name = t; } }
                    }
                }

                VerticalLayout {
                    spacing: 6px;
                    Text { text: "CPU BURST (MS)"; font-size: 10px; font-weight: 700; color: KernelColors.text-secondary; letter-spacing: 1.5px; }
                    Rectangle {
                        height: 38px; background: KernelColors.bg-input; border-radius: 2px; border-width: 1px; border-color: KernelColors.border-default;
                        SpinBox { value <=> root.process-burst; minimum: 1; maximum: 9999; }
                    }
                }

                HudSlider { label: "PRIORITY LEVEL (1-10)"; value: root.process-priority; min-val: 1; max-val: 10; changed(v) => { root.process-priority = Math.round(v); } }

                HorizontalLayout {
                    spacing: 12px; alignment: end;
                    HudButton { text: "CANCEL"; width: 120px; clicked => { root.cancel(); } }
                    HudButton { text: "SAVE CHANGES"; width: 160px; primary: true; clicked => { root.save(root.process-pid, root.process-name, root.process-burst, root.process-priority); } }
                }
            }
        }
    }
}
