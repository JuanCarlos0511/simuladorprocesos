// ============================================
// Component: ProcessTable
// Pantalla 3 — Listado de procesos con tabla
// ============================================

import { KernelColors } from "../../theme/colors.slint";
import { KernelTypo } from "../../theme/typography.slint";
import { SimState } from "../../globals.slint";
import { ProcessItem } from "../../structs.slint";
import { HudButton } from "../common/hud_button.slint";
import { HudBadge } from "../common/hud_badge.slint";
import { TableRow } from "table_row.slint";
import { ScrollView } from "std-widgets.slint";

export component ProcessTable inherits Rectangle {
    in property <[ProcessItem]> processes: [];
    in property <int> page: 0;
    in property <int> page-size: 10;
    in property <int> total-count: 0;
    callback edit-process(int);
    callback delete-process(int);
    callback next-page();
    callback prev-page();
    callback suspend-selected();
    callback resume-selected();
    callback toggle-select(int);

    background: KernelColors.bg-deep;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;

        // Title
        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                width: 4px;
                height: 28px;
                background: KernelColors.accent-cyan;
                border-radius: 2px;
            }
            Text {
                text: "LISTADO DE PROCESOS";
                font-size: KernelTypo.size-xl;
                font-weight: 800;
                color: KernelColors.text-primary;
                letter-spacing: 1px;
                vertical-alignment: center;
            }
        }

        // Actions
        HorizontalLayout {
            spacing: 12px;
            height: 40px;
            
            HudButton {
                text: "⊕ AÑADIR PROCESO";
                height: 32px;
                min-width: 140px;
                primary: true;
                clicked => { SimState.show-create-modal = true; }
            }

            Rectangle { width: 12px; }

            Text {
                text: "ACCIONES LOTE:";
                font-size: KernelTypo.size-xs;
                font-weight: 700;
                color: KernelColors.text-muted;
                letter-spacing: 1px;
                vertical-alignment: center;
            }

            HudButton {
                text: "⊘ SUSPENDER";
                height: 32px;
                min-width: 120px;
                clicked => { root.suspend-selected(); }
            }

            HudButton {
                text: "⊕ REANUDAR";
                height: 32px;
                min-width: 120px;
                clicked => { root.resume-selected(); }
            }

            Rectangle { } // spacer
        }

        // Table
        HudCard-like := Rectangle {
            background: KernelColors.bg-card;
            border-radius: 2px;
            border-width: 1px;
            border-color: KernelColors.border-default;

            VerticalLayout {
                // Table Header
                Rectangle {
                    height: 44px;
                    background: KernelColors.bg-elevated;
                    border-radius: 2px;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 0;

                        // Checkbox col
                        Rectangle { width: 40px; }

                        Rectangle {
                            width: 80px;
                            Text {
                                text: "PID";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 160px;
                            Text {
                                text: "NOMBRE";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 110px;
                            Text {
                                text: "ESTADO";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 100px;
                            Text {
                                text: "PRIORIDAD";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 80px;
                            Text {
                                text: "T. LLEGADA";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 80px;
                            Text {
                                text: "T. RÁFAGA";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 80px;
                            Text {
                                text: "MEMORIA";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            Text {
                                text: "ACCIONES";
                                font-size: KernelTypo.size-xs;
                                font-weight: 700;
                                color: KernelColors.text-secondary;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Table Body
                ScrollView {
                    VerticalLayout {
                        spacing: 0;

                        for proc[idx] in processes: TableRow {
                            proc: proc;
                            toggle-select => { root.toggle-select(proc.pid); }
                            edit-process => { root.edit-process(proc.pid); }
                            delete-process => { root.delete-process(proc.pid); }
                        }
                    }
                }
            }
        }

        // Pagination
        HorizontalLayout {
            spacing: 12px;
            height: 36px;

            Text {
                text: "Mostrando " + processes.length + " de " + total-count + " procesos";
                font-size: KernelTypo.size-sm;
                color: KernelColors.text-muted;
                vertical-alignment: center;
            }

            Rectangle { } // spacer

            HudButton {
                text: "< Anterior";
                height: 30px;
                min-width: 90px;
                enabled: page > 0;
                clicked => { root.prev-page(); }
            }

            HudButton {
                text: "Siguiente >";
                height: 30px;
                min-width: 90px;
                enabled: (page + 1) * page-size < total-count;
                clicked => { root.next-page(); }
            }
        }
    }
}
